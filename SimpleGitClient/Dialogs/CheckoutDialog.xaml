<Window x:Class="SimpleGitClient.Dialogs.CheckoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:bh="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lw="http://cyane.info/wpf"
        xmlns:vm="clr-namespace:SimpleGitClient.Dialogs"
        Title="{Binding Title}" 
        Width="520"
        SizeToContent="Height"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:CheckoutDialogViewModel}">
    <StackPanel Margin="10">
        <GroupBox Header="切り替え先">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <RadioButton Grid.Row="0" Grid.Column="0" Margin="4" VerticalAlignment="Center" Content="ブランチ"
                             GroupName="TargetType"
                             IsChecked="{Binding IsTargetBranch, Mode=TwoWay}"/>
                <ComboBox Grid.Row="0" Grid.Column="1" Margin="4"
                          ItemsSource="{Binding Branches}"
                          SelectedItem="{Binding SelectedBranch}"
                          IsEnabled="{Binding IsTargetBranch}"/>

                <RadioButton Grid.Row="2" Grid.Column="0" Margin="4" VerticalAlignment="Center" Content="コミット"
                             GroupName="TargetType"
                             IsChecked="{Binding IsTargetCommit, Mode=TwoWay}"/>
                <TextBox Grid.Row="2" Grid.Column="1" Margin="2"
                         Text="{Binding CommitHash, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsTargetCommit}"/>
            </Grid>
        </GroupBox>
        <GroupBox Header="オプション">
            <DockPanel>
                <CheckBox DockPanel.Dock="Left" Content="新しいブランチを作成" VerticalAlignment="Center"
                          IsChecked="{Binding IsCreateNewBranch}"/>
                <TextBox Margin="8,4"
                         Text="{Binding NewBranchName, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsCreateNewBranch}"/>
            </DockPanel>
        </GroupBox>
        
        <!-- ボタン類 -->
        <StackPanel Grid.Row="4" Grid.ColumnSpan="3" Margin="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button MinWidth="60" Margin="4" DockPanel.Dock="Right" Command="{Binding CancelCommand}" Content="キャンセル" IsCancel="True"/>
            <Button MinWidth="60" Margin="4" DockPanel.Dock="Right" Command="{Binding OkCommand}" Content="OK"/>
        </StackPanel>
    </StackPanel>
</Window>
