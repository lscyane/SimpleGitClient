<Window x:Class="SimpleGitClient.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleGitClient.Views"
        mc:Ignorable="d"
        Title="SettingsWindow" Height="450" Width="800">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
            <Button Content="InstallRegistory" Margin="5" Command="{Binding InstallRegCmd}"/>
            <Button Content="UninstallRegistory" Margin="5" Command="{Binding UninstallRegCmd}"/>
        </StackPanel>

        <Control/>
    </DockPanel>
</Window>
