<Window x:Class="SimpleGitClient.Views.CommitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleGitClient.Views"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:CommitWindowViewModel}"
        Title="CommitWindow" Height="450" Width="800">
    <DockPanel>
        <GroupBox Header="コミットメッセージ" DockPanel.Dock="Top" Margin="5">
            <DockPanel>
                <CheckBox DockPanel.Dock="Bottom" Content="最後のコミットをやり直し" Margin="5"/>
                <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}" 
                     Height="100"
                     AcceptsReturn="True" 
                     VerticalScrollBarVisibility="Auto"/>
            </DockPanel>
        </GroupBox>

        <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" Margin="5">
            <Button Content="コミット" Command="{Binding CommitCommand}" Margin="5"/>
            <Button Content="キャンセル" Command="{Binding CancelCommand}" Margin="5"/>
        </StackPanel>
        
        <GroupBox Header="Changes made">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="5">
                    <TextBlock Text="チェック：" VerticalAlignment="Center"/>
                    <Button Content="すべて" Command="{Binding SelectAllCommand}" Margin="5,0"/>
                    <Button Content="無し" Command="{Binding SelectNoneCommand}" Margin="5,0"/>
                </StackPanel>
                <ListView ItemsSource="{Binding CommitChanges}" Margin="5">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox Margin="5,0" IsChecked="{Binding IsChecked, Mode=TwoWay}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="パス" DisplayMemberBinding="{Binding Path}" />
                            <GridViewColumn Header="拡張子" DisplayMemberBinding="{Binding Extension}" />
                            <GridViewColumn Header="状態" DisplayMemberBinding="{Binding Status}" />
                            <GridViewColumn Header="追加行数" DisplayMemberBinding="{Binding AddLines}" />
                            <GridViewColumn Header="削除行数" DisplayMemberBinding="{Binding DelLines}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </GroupBox>
    </DockPanel>
</Window>
