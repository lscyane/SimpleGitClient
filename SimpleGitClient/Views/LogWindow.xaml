<Window x:Class="SimpleGitClient.Views.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vc="clr-namespace:SimpleGitClient.Converter"
        xmlns:v="clr-namespace:SimpleGitClient.Views"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance v:LogWindowViewModel}"
        Title="LogWindow" Height="600" Width="600">
    <DockPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20*"/>
            </Grid.RowDefinitions>

            <ListView Grid.Row="0"
                      ItemsSource="{Binding CommitLogs}"
                      SelectedItem="{Binding SelectedCommitLog}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="SHA" DisplayMemberBinding="{Binding Hash}" Width="60"/>
                        <GridViewColumn Header="メッセージ">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- ブランチ -->
                                        <ItemsControl ItemsSource="{Binding Branches}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border x:Name="BranchBorder" Background="#00C300" CornerRadius="3" Margin="2,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" x:Name="BranchText" Foreground="White" FontWeight="Bold" Margin="4,0"/>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="Remote">
                                                            <Setter TargetName="BranchBorder" Property="Background" Value="#FFDDAA"/>
                                                            <Setter TargetName="BranchText" Property="Foreground" Value="Black"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Current">
                                                            <Setter TargetName="BranchBorder" Property="Background" Value="#C80000"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- メッセージ -->
                                        <TextBlock Text="{Binding MessageShort}" />
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="作者" DisplayMemberBinding="{Binding Auther}" />
                        <GridViewColumn Header="日時" DisplayMemberBinding="{Binding CommitTime, StringFormat={}{0:yyyy/MM/dd HH:mm:ss}}" />
                    </GridView>
                </ListView.View>
            </ListView>
            
            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <TextBox Grid.Row="2"
                     Text="{Binding SelectedCommitLog.Message}" 
                     IsReadOnly="True"
                     TextWrapping="Wrap"/>

            <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <ListView Grid.Row="4"
                      ItemsSource="{Binding CommitChanges}"
                      Foreground="#0032A0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <!-- ダブルクリックで差分を開く -->
                        <EventSetter Event="MouseDoubleClick" Handler="ListViewItem_MouseDoubleClick"/>
                        <Style.Triggers>
                            <!-- 状態の種類に応じて行の色を変える -->
                            <DataTrigger Binding="{Binding Path=Status}" Value="Added">
                                <Setter Property="Foreground" Value="#9B0080"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Path=Status}" Value="Renamed">
                                <Setter Property="Foreground" Value="Blue"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Path=Status}" Value="Deleted">
                                <Setter Property="Foreground" Value="Maroon"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Path=Status}" Value="Conflicted">
                                <Setter Property="Foreground" Value="Red"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="パス">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image />
                                        <TextBlock Text="{Binding Path}" />
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="拡張子" DisplayMemberBinding="{Binding Extension}" />
                        <GridViewColumn Header="状態" DisplayMemberBinding="{Binding Status, Converter={x:Static vc:StatusTranslate.Converter}}" />
                        <GridViewColumn Header="追加" DisplayMemberBinding="{Binding AddLines}" />
                        <GridViewColumn Header="削除" DisplayMemberBinding="{Binding DelLines}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

    </DockPanel>
</Window>
