<Window x:Class="SimpleGitClient.Views.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleGitClient.Views"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:LogWindowViewModel}"
        Title="LogWindow" Height="600" Width="600">
    <DockPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20*"/>
            </Grid.RowDefinitions>

            <ListView Grid.Row="0"
                      ItemsSource="{Binding CommitLogs}"
                      SelectedItem="{Binding SelectedCommitLog}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="SHA" DisplayMemberBinding="{Binding Hash}" Width="60"/>
                        <GridViewColumn Header="メッセージ" DisplayMemberBinding="{Binding MessageShort}" />
                        <GridViewColumn Header="作者" DisplayMemberBinding="{Binding Auther}" />
                        <GridViewColumn Header="日時" DisplayMemberBinding="{Binding CommitTime, StringFormat={}{0:yyyy/MM/dd HH:mm:ss}}" />
                    </GridView>
                </ListView.View>
            </ListView>
            
            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <TextBox Grid.Row="2"
                     Text="{Binding SelectedCommitLog.Message}" 
                     IsReadOnly="True"
                     TextWrapping="Wrap"/>

            <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <ListView Grid.Row="4"
                      ItemsSource="{Binding CommitChanges}">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <EventSetter Event="MouseDoubleClick" Handler="ListViewItem_MouseDoubleClick"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="パス" DisplayMemberBinding="{Binding Path}" />
                        <GridViewColumn Header="拡張子" DisplayMemberBinding="{Binding Extension}" />
                        <GridViewColumn Header="状態" DisplayMemberBinding="{Binding Status}" />
                        <GridViewColumn Header="追加行数" DisplayMemberBinding="{Binding AddLines}" />
                        <GridViewColumn Header="削除行数" DisplayMemberBinding="{Binding DelLines}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

    </DockPanel>
</Window>
